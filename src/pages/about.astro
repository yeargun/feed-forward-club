---
import Layout from "../layouts/Layout.astro";
import CTA from "../components/CTA.astro";
import { activeChapters, formingChapters, chapters } from "../data/groups";
import { applyPath } from "../data/config";
---

<Layout
  title="About"
  description="FeedForwardClub is a small recurring meetup group for founders. You share your work, the room gives honest feedback on what to try next."
>
  <!-- ── HERO ────────────────────────────────────────────────────────────── -->
  <section class="about-hero">
    <div class="container">
      <span class="eyebrow">About</span>
      <h1>A room where founders share<br/><em>what they're building.</em></h1>
      <p class="lede">
        FeedForwardClub is a small recurring meetup group. You show up, share
        your work in progress, and the room gives you honest feedback on what
        to try next. That is the whole thing.
      </p>
    </div>
  </section>

  <hr class="rule" />

  <!-- ── HOW IT WORKS ────────────────────────────────────────────────────── -->
  <section class="section how">
    <div class="container">
      <span class="eyebrow">How it works</span>
      <h2>Three things happen at every session.</h2>

      <div class="steps">
        <div class="step">
          <div class="step-num">01</div>
          <h3>You show up.</h3>
          <p>
            Sessions run every two weeks. Four to eight people in a room —
            a chapter in your city, a topical circle online, or both.
            No agenda to prepare, no deck required.
          </p>
        </div>
        <div class="step">
          <div class="step-num">02</div>
          <h3>You take the hot seat.</h3>
          <p>
            Each person gets ten to fifteen minutes. You share whatever is
            on your table — idea, prototype, live product, a decision you
            can't make. The room asks questions. Then the room tells you
            what to try next.
          </p>
        </div>
        <div class="step">
          <div class="step-num">03</div>
          <h3>You commit to one thing.</h3>
          <p>
            Before you leave you say one thing you will try before the next
            session. Not a goal — a specific thing. At the next session,
            you open with what happened.
          </p>
        </div>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- ── SESSION TYPES ───────────────────────────────────────────────────── -->
  <section class="section types">
    <div class="container">
      <span class="eyebrow">Session types</span>
      <h2>Two formats, same room.</h2>
      <div class="type-grid">
        <div class="type-card type-card--primary">
          <div class="type-label">Regular session</div>
          <h3>Hot seat rounds</h3>
          <p>
            The standard format. Everyone gets a turn. You share your work,
            the room responds — questions first, feedback after. Blunt is
            allowed. Cruel is not.
          </p>
          <p class="type-cadence">Every two weeks</p>
        </div>
        <div class="type-card">
          <div class="type-label">Topic session</div>
          <h3>Someone leads a concept</h3>
          <p>
            One person brings something they know — a tool, a pattern, a
            hard lesson. Not a lecture: more like a show-and-tell where
            the room can push back. Occasional, whenever there is something
            worth sharing.
          </p>
          <p class="type-cadence">Whenever there is something worth sharing</p>
        </div>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- ── WHO IT'S FOR ────────────────────────────────────────────────────── -->
  <section class="section who">
    <div class="container">
      <div class="who-grid">
        <div class="who-left">
          <span class="eyebrow">Who it's for</span>
          <h2>If this sounds like you,<br/><em class="accent">you belong here.</em></h2>
        </div>
        <div class="who-right">
          <ul class="who-list">
            <li>
              <span class="check" aria-hidden="true">→</span>
              <div>
                <strong>You are building something.</strong>
                Idea stage, pre-MVP, live product — doesn't matter.
                What matters is you are working on it, not just thinking about it.
              </div>
            </li>
            <li>
              <span class="check" aria-hidden="true">→</span>
              <div>
                <strong>You want honest feedback, not validation.</strong>
                The room is not here to cheer you on. It is here to help you
                see what you cannot see yourself.
              </div>
            </li>
            <li>
              <span class="check" aria-hidden="true">→</span>
              <div>
                <strong>You give as well as you receive.</strong>
                You come prepared to be useful to others, not just
                to extract value for yourself.
              </div>
            </li>
            <li>
              <span class="check" aria-hidden="true">→</span>
              <div>
                <strong>You can sit in a room and listen.</strong>
                When someone else is on the hot seat, your job is to help them.
                Not to talk about yourself.
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- ── WHERE ───────────────────────────────────────────────────────────── -->
  <section class="section where">
    <div class="container">
      <span class="eyebrow">Where</span>
      <h2>Chapters by city. <em class="accent">More forming.</em></h2>
      <p class="sub">
        Each chapter is its own room with its own host. The culture is shared;
        the logistics are local.
      </p>

      <div class="chapter-list">
        {chapters.map(c => (
          <div class:list={["chapter-row", `s-${c.status}`]}>
            <div class="chapter-city">
              <span class:list={["cdot", `s-${c.status}`]} aria-hidden="true"></span>
              <span class="city-name">{c.city}</span>
              <span class="city-country">{c.country}</span>
            </div>
            <div class="chapter-status">{c.status}</div>
            {c.note && <div class="chapter-note">{c.note}</div>}
          </div>
        ))}
      </div>

      <p class="where-note">
        Don't see your city?
        <a href="/contact" class="link-accent">Write us</a> — if there's
        enough interest, we'll start it.
      </p>
    </div>
  </section>

  <!-- ── CTA ─────────────────────────────────────────────────────────────── -->
  <section class="section cta-section">
    <div class="container">
      <h2>Ready to bring your work <span class="mark">to the table?</span></h2>
      <p class="lede">Sessions run regularly. Apply and we'll read every line.</p>
      <CTA variant="stack" />
    </div>
  </section>
</Layout>

<style lang="scss">
  // — hero with gradient + dot background ------------------------------------
  .about-hero {
    position: relative;
    padding: clamp(80px, 11vw, 148px) 0 clamp(56px, 8vw, 100px);
    overflow: hidden;

    &::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      background-image:
        radial-gradient(ellipse 110% 70% at 50% -8%,  rgba(31, 58, 104, 0.13) 0%, transparent 65%),
        radial-gradient(ellipse 70%  50% at 100% 110%, rgba(184, 115, 40, 0.08) 0%, transparent 60%),
        radial-gradient(ellipse 50%  40% at 0%   80%,  rgba(31, 58, 104, 0.05) 0%, transparent 55%),
        radial-gradient(circle, rgba(31, 58, 104, 0.065) 1px, transparent 1px);
      background-size: 100% 100%, 100% 100%, 100% 100%, 26px 26px;
      -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
      mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
    }

    .container { position: relative; z-index: 1; }

    h1 {
      max-width: 680px;
      margin-top: 12px;
      em { font-style: italic; color: $accent; }
    }

    .lede {
      max-width: 560px;
      margin-top: 16px;
    }
  }

  // — how it works -----------------------------------------------------------
  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 36px;
  }

  @media (max-width: $bp-lg) { .steps { grid-template-columns: 1fr; } }

  .step {
    padding: 28px 24px;
    background: $paper;
    border: 1px solid $rule;
    border-radius: $radius;
    position: relative;

    .step-num {
      font-family: $font-serif;
      font-size: 13px;
      color: $accent;
      opacity: 0.6;
      letter-spacing: 0.05em;
      margin-bottom: 14px;
    }

    h3 {
      font-size: 20px;
      margin-bottom: 10px;
    }

    p {
      margin: 0;
      color: $ink-soft;
      font-size: 15px;
      line-height: 1.55;
    }
  }

  // — session types ----------------------------------------------------------
  .type-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 36px;
  }

  @media (max-width: $bp-md) { .type-grid { grid-template-columns: 1fr; } }

  .type-card {
    padding: 28px;
    background: $paper;
    border: 1px solid $rule;
    border-radius: $radius;

    &--primary {
      background: $accent;
      border-color: $accent-deep;
      color: $accent-ink;

      .type-label { color: rgba(255,255,255,0.6); }
      h3 { color: $accent-ink; }
      p { color: rgba(255,255,255,0.8); }
      .type-cadence { color: rgba(255,255,255,0.5); }
    }
  }

  .type-label {
    font-size: $fs-meta;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: $muted;
    font-weight: 600;
    margin-bottom: 10px;
  }

  .type-card h3 {
    font-size: 22px;
    margin-bottom: 12px;
  }

  .type-card p {
    color: $ink-soft;
    font-size: 15px;
    line-height: 1.55;
    margin: 0 0 0.8em;
  }

  .type-cadence {
    font-size: 13px;
    font-style: italic;
    color: $muted;
    margin: 0;
  }

  // — who it's for -----------------------------------------------------------
  .who-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(40px, 7vw, 96px);
    align-items: start;
  }

  @media (max-width: $bp-lg) { .who-grid { grid-template-columns: 1fr; } }

  .who-left {
    h2 em.accent { font-style: italic; color: $accent; }
    h2 { position: sticky; top: 88px; }
  }

  @media (max-width: $bp-md) {
    .who-left h2 { position: static; }
  }

  .who-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .who-list li {
    display: grid;
    grid-template-columns: 20px 1fr;
    gap: 14px;
    padding: 20px 0;
    border-bottom: 1px solid $rule;
    font-size: 15px;
    line-height: 1.55;

    &:first-child { border-top: 1px solid $rule; }

    strong { color: $ink; display: block; margin-bottom: 4px; }
    color: $ink-soft;
  }

  .check {
    color: $accent;
    font-size: 13px;
    padding-top: 3px;
  }

  // — where ------------------------------------------------------------------
  .where .sub {
    color: $ink-soft;
    margin: 0 0 32px;
    max-width: 560px;
  }

  .chapter-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 600px;
  }

  .chapter-row {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 12px 16px;
    padding: 14px 0;
    border-bottom: 1px solid $rule;
    font-size: 14px;

    &:first-child { border-top: 1px solid $rule; }
  }

  @media (min-width: $bp-sm) {
    .chapter-row {
      grid-template-columns: 1fr auto auto;
    }
  }

  @media (max-width: ($bp-sm - 1px)) {
    .chapter-status { justify-self: start; }
    .chapter-city { flex-wrap: wrap; }
  }

  .chapter-city {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .cdot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;

    &.s-active  { background: $accent; box-shadow: 0 0 0 2px $accent-soft; }
    &.s-forming { background: color-mix(in srgb, $accent 55%, $muted 45%); }
    &.s-planned { background: $muted; opacity: 0.5; }
  }

  .city-name { font-weight: 500; color: $ink; }
  .city-country { color: $muted; font-size: 13px; }

  .chapter-status {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: $muted;
    font-weight: 600;
  }

  .chapter-note {
    grid-column: 1 / -1;
    font-size: 13px;
    color: $muted;
    padding-left: 18px;
    margin-top: -8px;
    padding-bottom: 4px;
  }

  .where-note {
    margin-top: 20px;
    font-size: 14px;
    color: $ink-soft;
  }

  // — cta section ------------------------------------------------------------
  .cta-section {
    background: $paper;
    border-top: 1px solid $rule;
    border-bottom: 1px solid $rule;
    position: relative;
    overflow: hidden;

    &::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background-image:
        radial-gradient(ellipse 80% 120% at 50% 100%, rgba(31, 58, 104, 0.08), transparent),
        radial-gradient(circle, rgba(31, 58, 104, 0.04) 1px, transparent 1px);
      background-size: 100% 100%, 22px 22px;
    }

    .container { position: relative; z-index: 1; }

    h2 { margin-bottom: 12px; }
    .lede { margin-bottom: 28px; max-width: 440px; }
  }
</style>
