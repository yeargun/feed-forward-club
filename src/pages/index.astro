---
import Layout from "../layouts/Layout.astro";
import CTA from "../components/CTA.astro";
import Supporters from "../components/Supporters.astro";
import { memberCount, countries } from "../data/members";
import Globe from "../components/Globe.astro";
import {
  chapters,
  activeChapters,
  formingChapters,
} from "../data/groups";
import { memberStatus } from "../data/batches";
import { applyPath } from "../data/config";
import HomeEvents from "../components/HomeEvents.astro";

const howPreamble = [
  "Feedback is not only a meeting activity. Members give and get feedback on their products between sessions and in the room, so the work keeps moving instead of waiting two weeks.",
  "Every session starts with the work itself: what changed, what is in the backlog, which features matter, what should be cut, what is blocked, and how the next moves should be ordered.",
  "Chit-chat is fine, but very little. The room exists to improve the product, not to fill time.",
  "Respect the shared clock. Five minutes from one person is not just five minutes. It is five minutes multiplied by everyone listening, so we stay sharp and on point.",
] as const;

const howSteps = [
  {
    title: "Bring the current product.",
    body: "Show what exists now: product, prototype, backlog, user problem, feature decision, or the thing that is stuck. No deck required. Real work beats presentation.",
  },
  {
    title: "The room pressure-tests it.",
    body: "People ask questions, challenge the order of work, point at weak assumptions, and suggest what to try next. Feedback is specific: backlog, features, positioning, users, execution.",
  },
  {
    title: "Leave with the next move.",
    body: "Before the session ends, you choose one concrete thing to do before the next meeting. At the next session, you open with what happened and the room keeps building from there.",
  },
] as const;

const values = [
  {
    title: "Bias, almost not",
    body: "Hard achievers and first-time builders in the same room",
  },
  {
    title: "Obsession over résumé",
    body: "Previous accomplishments matter. They matter less here than what you are building now.",
  },
  {
    title: "Genuine and respectful",
    body: "Blunt is allowed. Cruel is not.",
  },
  {
    title: "Responsibility, not rank",
    body: "Someone still has to protect the standard until the culture can do it alone.",
  },
];

---

<Layout
  description="Founders' circle: share the build, hear what to try next in small global rooms. Chapters are global WhatsApp groups—IRL sometimes where it makes sense—plus topical circles by obsession."
  organization
>
  <!-- HERO -->
  <section class="hero">
    <div class="wide hero-grid">
      <div class="hero-copy">
        {memberStatus.accepting && (
          <a href={applyPath} class="session-chip">
            <span class="pulse" aria-hidden="true"></span>
            Sessions running · now taking members
          </a>
        )}
        <h1>Get feedback.<br/>Learn from the best builders.<br/>Share your expertise.</h1>

        <p class="lede">
          Small room. High standards.
        </p>
        <CTA variant="stack" />

        <div class="meta">
          <div class="meta-item">
            <span class="dot"></span>
            {activeChapters.length} active, {formingChapters.length} forming
          </div>
          <div class="meta-item">
            <span class="dot amber"></span>
            Sessions running now
          </div>
        </div>
      </div>

      <div class="hero-globe">
        <Globe
          chapters={chapters}
          size={420}
          memberCount={memberCount}
          countries={countries}
        />
      </div>
    </div>
  </section>

  <HomeEvents />

  <hr class="rule" />

  <section class="section how-it-works" aria-labelledby="how-it-works-heading">
    <div class="container">
      <span class="eyebrow">How it works</span>
      <h2 id="how-it-works-heading">Three things happen at every session.</h2>
      <div class="how-preamble">
        {howPreamble.map((p) => (
          <p>{p}</p>
        ))}
      </div>
      <div class="how-grid">
        {howSteps.map((step, i) => (
          <div class="how-step">
            <div class="num">0{i + 1}</div>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- CULTURE -->
  <section class="section values">
    <div class="container">
      <span class="eyebrow">Culture</span>
      <h2>Four things we try to get right.</h2>
      <div class="value-grid">
        {values.map((v, i) => (
          <div class="value">
            <div class="num">0{i + 1}</div>
            <h3>{v.title}</h3>
            <p>{v.body}</p>
          </div>
        ))}
      </div>
      <p class="more">
        <a href="/manifesto" class="link-accent">Full manifesto →</a>
      </p>
    </div>
  </section>

  <hr class="rule" />

  <!-- GROUPS TEASER -->
  <section class="section groups-teaser">
    <div class="container">
      <div class="teaser-head">
        <span class="eyebrow">Groups</span>
        <h2>Find your <em class="accent">chapter room.</em></h2>
        <p class="sub">
          Each chapter is a global WhatsApp group for founders building in <strong>deep tech</strong>, <strong>software</strong>, and <strong>hardware</strong>—mostly online, with occasional meetups where there's enough local interest. Don't see yours? Help us start it.
        </p>
      </div>

      <div class="teaser-grid">
        <div class="teaser-col">
          <h4>Chapters</h4>
          <ul>
            {chapters.map((c) => (
              <li>
                <span class:list={["sdot", `s-${c.status}`]} aria-hidden="true"></span>
                <a href={`/groups#chapters`}>{c.city}, {c.country}</a>
                <span class="status-lab">{c.status}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="teaser-foot">
        <a href="/groups" class="btn btn-ghost">Browse all groups</a>
      </div>
    </div>
  </section>

  <!-- SUPPORTERS -->
  <Supporters />

  <!-- CTA -->
  <section class="section cta">
    <div class="container">
      <h2>Obsessed with something? <span class="mark">Bring it to the table.</span></h2>
      <CTA variant="stack" />
    </div>
  </section>
</Layout>

<style lang="scss">
  // — hero --------------------------------------------------------------------
  .hero {
    position: relative;
    padding: clamp(64px, 9vw, 120px) 0 clamp(28px, 5vw, 64px);
    overflow: hidden;

    &::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      background-image:
        radial-gradient(900px 400px at 75% 10%, rgba(31, 58, 104, 0.13), transparent 65%),
        radial-gradient(600px 300px at 5% 85%, rgba(184, 115, 40, 0.09), transparent 65%),
        radial-gradient(400px 200px at 50% 50%, rgba(31, 58, 104, 0.06), transparent 70%),
        radial-gradient(circle, rgba(31, 58, 104, 0.09) 1px, transparent 1px);
      background-size: 100% 100%, 100% 100%, 100% 100%, 24px 24px;
      -webkit-mask-image: linear-gradient(to bottom, black 45%, transparent 100%);
      mask-image: linear-gradient(to bottom, black 45%, transparent 100%);
    }
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: clamp(32px, 6vw, 80px);
    align-items: start;
    min-width: 0;
  }

  .hero-copy,
  .hero-globe {
    min-width: 0;
  }

  @media (min-width: #{$bp-lg + 1px}) {
    .hero-globe {
      justify-self: end;
    }
  }

  .hero-copy h1 em.accent { font-style: italic; color: $accent; }
  .hero-copy .lede { max-width: 480px; margin-top: 12px; }
  .hero-copy :global(.ff-mark) { margin-top: 0.15em; }

  .session-chip {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 6px 14px;
    border-radius: 999px;
    background: $accent-soft;
    color: $accent-deep;
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 18px;
    text-decoration: none;
    max-width: 100%;
    transition: background 140ms ease;

    strong { font-weight: 600; }
    .closes { opacity: 0.8; }
    &:hover { background: color-mix(in srgb, $accent-soft 70%, $accent 10%); }
  }

  .pulse {
    width: 8px; height: 8px; border-radius: 50%;
    background: $amber;
    box-shadow: 0 0 0 3px $amber-soft;
    animation: pulse-dot 2.4s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%      { transform: scale(1.3); opacity: 0.75; }
  }
  @media (prefers-reduced-motion: reduce) { .pulse { animation: none; } }

  .meta {
    margin-top: 32px;
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    color: $ink-soft;
    font-size: 14px;
  }
  .meta-item { display: inline-flex; align-items: center; gap: 8px; }
  .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: $ok;
    box-shadow: 0 0 0 3px rgba(47, 107, 74, 0.18);
    &.amber { background: $amber; box-shadow: 0 0 0 3px $amber-soft; }
  }

  @media (max-width: $bp-lg) {
    .hero-grid {
      grid-template-columns: 1fr;
      align-items: center;
    }
    .hero-globe {
      max-width: min(340px, 100%);
      margin: 0 auto;
      width: 100%;
      justify-self: center;
    }
  }

  // — values ------------------------------------------------------------------
  .values {
    position: relative;
    background: $bg-deep;

    &::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background-image: radial-gradient(circle, rgba(31, 58, 104, 0.04) 1px, transparent 1px);
      background-size: 22px 22px;
      -webkit-mask-image: radial-gradient(ellipse 80% 100% at 50% 50%, black, transparent);
      mask-image: radial-gradient(ellipse 80% 100% at 50% 50%, black, transparent);
      z-index: 0;
    }
  }

  .value-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 32px;
  }
  @media (max-width: $bp-md) { .value-grid { grid-template-columns: 1fr; } }

  .value {
    padding: 24px;
    background: $paper;
    border: 1px solid $rule;
    border-radius: $radius;
    position: relative;
    box-shadow: 0 1px 2px rgba(11, 11, 13, 0.04);
    transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease;

    &:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(11, 11, 13, 0.08);
      border-color: color-mix(in srgb, $accent 24%, $rule 76%);
    }

    .num {
      position: absolute;
      top: 18px;
      right: 22px;
      font-family: $font-serif;
      color: $accent;
      font-size: 16px;
    }
    h3 { margin-bottom: 8px; font-size: 20px; }
    p { margin: 0; color: $ink-soft; font-size: 15px; }
  }

  .more { margin-top: 24px; position: relative; z-index: 1; }

  .how-it-works {
    h2 { max-width: 32rem; }
    .how-preamble {
      max-width: 42rem;
      margin: 0 0 28px;
      p {
        margin: 0 0 0.9em;
        color: $ink-soft;
        font-size: 16px;
        line-height: 1.55;
      }
      p:last-child { margin-bottom: 0; }
    }
    .how-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
      margin-top: 8px;
      @media (min-width: $bp-lg) {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    .how-step {
      padding: 24px;
      background: $paper;
      border: 1px solid $rule;
      border-radius: $radius;
      position: relative;
      box-shadow: 0 1px 2px rgba(11, 11, 13, 0.04);
      transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease;
      &:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(11, 11, 13, 0.08);
        border-color: color-mix(in srgb, $accent 24%, $rule 76%);
      }
      .num {
        position: absolute;
        top: 18px;
        right: 22px;
        font-family: $font-serif;
        color: $accent;
        font-size: 16px;
      }
      h3 { margin-bottom: 8px; font-size: 20px; }
      p { margin: 0; color: $ink-soft; font-size: 15px; }
    }
  }

  // — groups teaser -----------------------------------------------------------
  .groups-teaser {
    .teaser-head {
      max-width: 640px;
      margin: 0 auto 32px;
      text-align: center;

      h2 em.accent { font-style: italic; color: $accent; }
      h2 { margin-bottom: 10px; }
      .sub { color: $ink-soft; margin: 0; }
      .sub strong { color: $ink; font-weight: 600; }
    }

    .teaser-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
      max-width: 560px;
      margin: 0 auto;
    }

    .teaser-col {
      padding: 24px;
      background: $paper;
      border: 1px solid $rule;
      border-radius: $radius;
      box-shadow: 0 1px 2px rgba(11, 11, 13, 0.04);

      h4 {
        font-family: $font-sans;
        font-size: $fs-meta;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: $muted;
        font-weight: 600;
        margin: 0 0 14px;
      }

      ul { list-style: none; margin: 0; padding: 0; }

      li {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        align-items: center;
        gap: 10px;
        padding: 8px 0;
        border-bottom: 1px solid $rule-soft;
        font-size: 14px;

        &:last-child { border-bottom: 0; }

        a {
          color: $ink;
          text-decoration: none;
          overflow-wrap: anywhere;
        }
        a:hover { color: $accent-deep; }
      }

      .status-lab {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: $muted;
        font-weight: 600;
      }
    }

    .sdot {
      width: 8px; height: 8px; border-radius: 50%;
      &.s-active  { background: $accent; box-shadow: 0 0 0 2px $accent-soft; }
      &.s-forming { background: color-mix(in srgb, $accent 55%, $muted 45%); }
      &.s-planned { background: $muted; opacity: 0.6; }
    }

    .teaser-foot {
      margin-top: 28px;
      display: flex;
      justify-content: center;
    }
  }

  // — cta ---------------------------------------------------------------------
  .cta {
    position: relative;
    overflow: hidden;
    background: $bg-deep;
    border-top: 1px solid $rule;
    border-bottom: 1px solid $rule;

    &::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background-image:
        radial-gradient(ellipse 70% 90% at 50% 100%, rgba(31, 58, 104, 0.09), transparent),
        radial-gradient(circle, rgba(31, 58, 104, 0.05) 1px, transparent 1px);
      background-size: 100% 100%, 22px 22px;
    }

    .container { position: relative; z-index: 1; }
  }
</style>
