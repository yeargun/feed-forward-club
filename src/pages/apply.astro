---
import Layout from "../layouts/Layout.astro";
import Form from "../components/Form.astro";
import { applyEndpoint, applyEmail, applyMailto } from "../data/config";
import { memberStatus } from "../data/batches";

const fields = [
  {
    name: "name",
    label: "Your name",
    required: true,
    placeholder: "First & last",
    autocomplete: "name",
  },
  {
    name: "email",
    label: "Email",
    type: "email" as const,
    required: true,
    placeholder: "you@domain.com",
    autocomplete: "email",
  },
  {
    name: "city",
    label: "Where are you based?",
    required: true,
    placeholder: "City, country",
  },
  {
    name: "links",
    label: "Links (optional)",
    placeholder: "Website, GitHub, X, LinkedIn, anything relevant",
  },
  {
    name: "obsession",
    label: "What are you obsessed with right now?",
    type: "textarea" as const,
    required: true,
    rows: 4,
    placeholder: "The thing you cannot stop thinking about.",
    hint: "Two or three sentences is plenty. Specificity beats polish.",
  },
  {
    name: "hot_seat",
    label: "If we gave you a hot seat, what would you bring?",
    type: "textarea" as const,
    required: true,
    rows: 4,
    placeholder: "Idea, landing page, prototype, MVP, or live product. Whatever would benefit from a sharp room.",
  },
  {
    name: "referrer",
    label: "Anyone already in the room vouching for you? (optional)",
    placeholder: "A name or handle",
  },
];
---

<Layout
  title="Apply"
  description="Join FeedForwardClub — a small founders' circle where you share your work and get real feedback. Sessions run regularly."
>
  <section class="hero">
    <div class="container">
      <span class="eyebrow">Apply</span>
      {memberStatus.accepting && (
        <div class="session-chip">
          <span class="pulse" aria-hidden="true"></span>
          Sessions running · taking new members
        </div>
      )}
      <h1>Tell us what you are <em class="accent">obsessed with.</em></h1>
      <p class="lede">
        The room is small and stays small. If we gave you ten minutes on the
        hot seat, what would you put on the table? Keep it short. We read
        every line.
      </p>
    </div>
  </section>

  <hr class="rule" />

  <section class="section form-section">
    <div class="container grid">
      <div class="form-col">
        <Form
          formId="apply-form"
          formType="apply"
          endpoint={applyEndpoint}
          fields={fields}
          submitLabel="Send application"
          successMessage="Got it. We will read every line and come back within a week."
          errorMessage="Didn't go through. Try again in a moment, or email us directly."
        />

        <p class="fallback">
          Prefer email? Write to
          <a href={applyMailto} class="link-accent">{applyEmail}</a>
          with the same information. Either channel reaches us.
        </p>
      </div>

      <aside class="side">
        <div class="card">
          <h4>What we look for</h4>
          <ul>
            <li>You are building, pre-building, or preparing to leave your job to build.</li>
            <li>You give useful, specific advice as generously as you take it.</li>
            <li>You can sit in a room for a few hours without making it about you.</li>
          </ul>
        </div>
        <div class="card">
          <h4>What happens next</h4>
          <ol>
            <li>We read your answers.</li>
            <li>We reply within a week. Yes, not yet, or let us talk more.</li>
            <li>If it is a yes, you join the circle and come to the next session.</li>
          </ol>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<style lang="scss">
  .hero {
    padding: clamp(72px, 10vw, 140px) 0 clamp(24px, 4vw, 48px);

    .lede { max-width: 640px; margin-top: 16px; }
    h1 em.accent { font-style: italic; color: $accent; }
  }

  .session-chip {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 6px 14px;
    border-radius: 999px;
    background: $accent-soft;
    color: $accent-deep;
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 20px;
    max-width: 100%;

    strong { font-weight: 600; }
    .closes { color: $accent-deep; opacity: 0.8; }
  }

  .pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: $amber;
    box-shadow: 0 0 0 3px $amber-soft;
    animation: pulse 2.4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%      { transform: scale(1.3); opacity: 0.75; }
  }
  @media (prefers-reduced-motion: reduce) {
    .pulse { animation: none; }
  }

  .form-section { padding-top: clamp(32px, 5vw, 56px); }

  .grid {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: start;
  }
  @media (max-width: $bp-lg) {
    .grid { grid-template-columns: 1fr; }
  }

  .fallback {
    margin-top: 28px;
    padding-top: 20px;
    border-top: 1px solid $rule;
    color: $muted;
    font-size: 14px;
  }

  .side {
    display: grid;
    gap: 20px;
  }

  .card {
    padding: 24px;
    background: $paper;
    border: 1px solid $rule;
    border-radius: $radius;

    h4 {
      font-family: $font-sans;
      font-size: $fs-meta;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: $accent-deep;
      margin: 0 0 12px;
      font-weight: 600;
    }

    ul, ol { margin: 0; padding-left: 20px; }
    li { margin: 6px 0; color: $ink-soft; }
  }
</style>
