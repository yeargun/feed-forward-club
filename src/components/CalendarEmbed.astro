---
import { calendarEmbedUrl } from "../data/config";

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

{
  calendarEmbedUrl && (
    <div class:list={["calendar-embed", { "calendar-embed--compact": compact }]}>
      <iframe
        title="FeedForwardClub public calendar"
        src={calendarEmbedUrl}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      />
    </div>
  )
}

<style lang="scss">
  .calendar-embed {
    border-radius: $radius;
    border: 1px solid $rule;
    overflow: hidden;
    background: $paper;
    box-shadow: 0 1px 2px $shadow;

    iframe {
      display: block;
      width: 100%;
      height: 560px;
      border: 0;
    }
  }

  .calendar-embed--compact iframe {
    height: min(420px, 55vh);
  }

  @media (max-width: $bp-md) {
    .calendar-embed iframe {
      height: 480px;
    }
    .calendar-embed--compact iframe {
      height: min(380px, 50vh);
    }
  }
</style>
