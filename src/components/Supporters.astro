---
import { supporters } from "../data/supporters";

interface Props {
  variant?: "full" | "strip";
}

const { variant = "full" } = Astro.props;

// Double the list so the marquee loops seamlessly when translated -50%.
const marqueeList = [...supporters, ...supporters];
---

<section class:list={["supporters", `v-${variant}`]}>
  <div class="band">
    <div class="inner">
      {variant === "full" ? (
        <div class="stack">
          <p class="eyebrow-grad">Supported by</p>
          <div class="logo-marquee" aria-label="Partner programs">
            <div class="logo-track">
              {marqueeList.map((s, i) => (
                <a
                  class="logo-hit"
                  href={s.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  style={`--brand: ${s.accent}`}
                  aria-label={i < supporters.length ? `${s.name}, ${s.program} (opens in a new tab)` : undefined}
                  aria-hidden={i >= supporters.length ? "true" : undefined}
                  tabindex={i >= supporters.length ? -1 : undefined}
                >
                  <img
                    src={s.logoUrl}
                    alt={i < supporters.length ? s.name : ""}
                    height="36"
                    loading="lazy"
                    decoding="async"
                  />
                  <span class="logo-cap">{s.program}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      ) : (
        <div class="stack stack--strip">
          <p class="eyebrow-grad">Supported by</p>
          <div class="logo-marquee logo-marquee--slim">
            <div class="logo-track">
              {marqueeList.map((s, i) => (
                <a
                  class="logo-hit"
                  href={s.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  style={`--brand: ${s.accent}`}
                  aria-label={i < supporters.length ? `${s.name}, ${s.program} (opens in a new tab)` : undefined}
                  aria-hidden={i >= supporters.length ? "true" : undefined}
                  tabindex={i >= supporters.length ? -1 : undefined}
                >
                  <img
                    src={s.logoUrl}
                    alt={i < supporters.length ? s.name : ""}
                    height="28"
                    loading="lazy"
                    decoding="async"
                  />
                  <span class="logo-cap">{s.program}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style lang="scss">
  .supporters {
    .band {
      width: 100%;
      padding: clamp(40px, 6vw, 72px) 0;
      background: $bg;
    }

    .inner {
      max-width: min(84rem, 100%);
      margin: 0 auto;
      padding: 0 $pad;
    }

    .stack {
      display: flex;
      flex-direction: column;
      gap: clamp(12px, 2vw, 20px);
    }

    .stack--strip {
      padding: 8px 0 0;
    }

    .eyebrow-grad {
      margin: 0 0 20px;
      text-align: center;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      line-height: 1.3;
      color: $muted;
    }

    // — marquee ---------------------------------------------------------------
    .logo-marquee {
      position: relative;
      overflow: hidden;
      width: 100%;
      -webkit-mask-image: linear-gradient(
        to right,
        transparent 0,
        black 8%,
        black 92%,
        transparent 100%
      );
      mask-image: linear-gradient(
        to right,
        transparent 0,
        black 8%,
        black 92%,
        transparent 100%
      );
    }

    .logo-track {
      display: flex;
      align-items: flex-start;
      width: max-content;
      padding: 4px 0 8px;
      animation: ffc-marquee 32s linear infinite;
      will-change: transform;
    }

    .logo-marquee:hover .logo-track,
    .logo-marquee:focus-within .logo-track {
      animation-play-state: paused;
    }

    @keyframes ffc-marquee {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    .logo-hit {
      position: relative;
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      gap: 8px;
      text-decoration: none;
      color: $muted;
      padding: 6px 4px 0;
      margin-right: clamp(48px, 7vw, 96px);
      flex-shrink: 0;
      max-width: 168px;
      transition:
        filter 0.35s ease,
        opacity 0.35s ease,
        transform 0.35s ease;

      img {
        display: block;
        height: 36px;
        width: auto;
        max-width: 160px;
        object-fit: contain;
        filter: grayscale(1) contrast(0.85);
        opacity: 0.55;
        transition: filter 0.35s ease, opacity 0.35s ease;
      }

      .logo-cap {
        display: block;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.02em;
        line-height: 1.25;
        text-align: center;
        text-wrap: balance;
        color: $ink-soft;
      }

      &:hover,
      &:focus-visible {
        transform: scale(1.05);
        img {
          filter: grayscale(0) contrast(1);
          opacity: 1;
        }
        .logo-cap {
          color: $ink;
        }
      }

      &:focus-visible {
        outline: 2px solid color-mix(in srgb, var(--brand) 60%, $ink);
        outline-offset: 4px;
        border-radius: 4px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .logo-track { animation: none; }
      .logo-hit {
        transition: filter 0.2s ease, opacity 0.2s ease;
        &:hover, &:focus-visible { transform: none; }
      }
    }

    // — strip variant ---------------------------------------------------------
    &.v-strip .band { padding: 32px 0; }

    .stack--strip {
      .eyebrow-grad { margin: 0 0 4px; }
    }

    .logo-marquee--slim {
      .logo-hit {
        max-width: 140px;
        margin-right: clamp(40px, 6vw, 72px);
        gap: 6px;
      }
      img { height: 28px; max-width: 140px; }
      .logo-cap { font-size: 10px; }
    }
  }
</style>
