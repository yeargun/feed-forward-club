---
import { applyPath, contactPath } from "../data/config";
import Logo from "./Logo.astro";

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const peoplePaths = new Set([
  "/manifesto",
  "/groups",
  "/people",
  "/gallery",
  "/crew",
  "/alumnis",
]);
const isPeople = peoplePaths.has(pathname);
const isEvents = pathname === "/events";

const peopleTabs = [
  { id: "groups", href: "/groups", label: "Groups", hint: "Global chapter rooms and topical circles." },
  { id: "people", href: "/people", label: "People", hint: "Who is in the room: members, operators, friends." },
  { id: "gallery", href: "/gallery", label: "Gallery", hint: "Moments and sessions, not feed filler." },
  { id: "crew", href: "/crew", label: "Crew", hint: "People who keep the lights on." },
  { id: "alumni", href: "/alumnis", label: "Alumni", hint: "Graduates who still drop by." },
] as const;

const defaultPeopleHint =
  peopleTabs.find((t) => pathname === t.href)?.id ?? "groups";
---

<header class="site-header">
  <div class="site-header-shell" data-header-shell>
    <div class="row">
      <a href="/" class="brand" aria-label="FeedForwardClub home">
        <Logo variant="mark" class="header-mark" />
        <span class="brand-name"><span class="b-feed">feed</span><span class="b-fwd">forward</span><span class="b-club">club</span></span>
      </a>
      <nav class="top-nav" aria-label="Primary">
        <ul class="top-list">
        <li class:list={["nav-dd", { "is-active": isPeople }]} data-nav-dropdown>
          <button
            type="button"
            class="sub-trigger"
            data-dropdown-trigger
            aria-haspopup="true"
            aria-expanded="false"
            aria-current={isPeople ? "page" : undefined}
          >
            People
            <span class="chev" aria-hidden="true"></span>
          </button>
          <div class="sub-panel" data-dropdown-content>
            <a class="sub-feature" href="/manifesto">
              <span class="sub-feature-eyebrow">Principles</span>
              <span class="sub-feature-title">Manifesto</span>
              <span class="sub-feature-hint">How we keep advice practical.</span>
            </a>
            <div
              class="sub-tabs-wrap"
              data-people-hints
              data-people-default={defaultPeopleHint}
            >
              <div class="sub-tabs" role="tablist" aria-label="People sections">
                {peopleTabs.map((t) => {
                  const active = pathname === t.href;
                  return (
                    <a
                      href={t.href}
                      class:list={["sub-tab", { active }]}
                      data-people-tab={t.id}
                    >
                      {t.label}
                    </a>
                  );
                })}
              </div>
              <div class="tab-stage" aria-live="polite">
                {peopleTabs.map((t) => {
                  const active = t.id === defaultPeopleHint;
                  return (
                    <div
                      class:list={["tab-pane", { "tab-pane-active": active }]}
                      data-people-pane={t.id}
                    >
                      <div class:list={["pane-img", `pane-img--${t.id}`]}></div>
                      <div class="pane-info">
                        <p class="pane-desc">{t.hint}</p>
                        <a href={t.href} class="pane-link">Browse {t.label} →</a>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        </li>
        <li>
          <a
            href="/events"
            class:list={["top-link", { active: isEvents }]}
            aria-current={isEvents ? "page" : undefined}
          >
            Events
          </a>
        </li>
        <li class="nav-cta-item">
          <a
            href={applyPath}
            class:list={[
              "btn",
              "header-cta",
              "header-cta--primary",
              { "is-nav-active": pathname === applyPath },
            ]}
          >
            Apply
          </a>
        </li>
        <li class="nav-cta-item">
          <a
            href={contactPath}
            class:list={[
              "btn",
              "btn-ghost",
              "header-cta",
              { "is-nav-active": pathname === contactPath },
            ]}
          >
            Contact
          </a>
        </li>
        </ul>
      </nav>
      <div class="actions">
        <a
          href={applyPath}
          class:list={[
            "btn",
            "header-cta",
            "header-cta--primary",
            { "is-nav-active": pathname === applyPath },
          ]}
        >
          Apply
        </a>
        <a
          href={contactPath}
          class:list={[
            "btn",
            "btn-ghost",
            "header-cta",
            { "is-nav-active": pathname === contactPath },
          ]}
        >
          Contact
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  import "../scripts/header-menus";
</script>

<style lang="scss">
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 0;

    @media (min-width: #{$bp-md + 1px}) {
      padding-top: 12px;
    }
  }

  .site-header-shell {
    width: 100%;
    max-width: $max-wide;
    margin: 0 auto;
    background: color-mix(in srgb, $bg 90%, transparent);
    backdrop-filter: saturate(160%) blur(10px);
    -webkit-backdrop-filter: saturate(160%) blur(10px);
    border: 1px solid transparent;
    border-radius: 0;
    box-shadow: 0 0 0 rgba(17, 21, 28, 0);
    overflow: visible;
  }

  .site-header.is-dense .site-header-shell {
    border-color: $rule;
    border-radius: 15px;
    box-shadow: 0 10px 28px rgba(17, 21, 28, 0.1);
  }

  .row {
    display: flex;
    align-items: center;
    gap: 20px;
    min-height: 64px;
    padding: 0 clamp(20px, 4vw, 40px);
    transition: min-height 0.22s ease, gap 0.22s ease;
  }

  .site-header.is-dense .row {
    min-height: 50px;
    gap: 16px;
  }

  .brand {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    transition: gap 0.22s ease;

    &:hover { color: inherit; text-decoration: none; }
  }

  .site-header.is-dense .brand { gap: 8px; }

  :global(.header-mark) {
    height: 26px;
    width: auto;
    flex-shrink: 0;
    transition: transform 260ms ease;
  }

  .brand:hover :global(.header-mark) { transform: translateX(2px); }
  .site-header.is-dense :global(.header-mark) { height: 22px; }

  .brand-name {
    font-family: "Avenir Next", Gotham, Montserrat, "Helvetica Neue", Arial, sans-serif;
    font-size: 16px;
    letter-spacing: -0.01em;
    line-height: 1;
    color: $ink;
    transition: font-size 0.22s ease;
  }

  .b-feed  { font-weight: 300; }
  .b-fwd   { font-weight: 800; }
  .b-club  { font-weight: 300; }

  .site-header.is-dense .brand-name { font-size: 15px; }

  .top-nav {
    margin-left: auto;
  }

  .top-list {
    list-style: none;
    display: flex;
    align-items: stretch;
    gap: 2px;
    margin: 0;
    padding: 0;
  }

  .sub-trigger {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 8px 12px;
    font-size: 14px;
    color: $ink-soft;
    font-weight: 500;
    font-family: inherit;
    background: none;
    border: 0;
    border-radius: $radius-sm;
    cursor: pointer;
    text-decoration: none;
    transition: color 0.12s ease, background 0.12s ease;

    &:hover {
      color: $ink;
      background: rgba(20, 20, 20, 0.04);
    }
  }

  .nav-dd.is-active .sub-trigger,
  .sub-trigger[aria-current="page"] {
    color: $accent-deep;
  }

  .chev {
    display: block;
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 4px solid currentColor;
    margin-top: 1px;
    opacity: 0.55;
    transition: transform 0.2s ease;
  }

  .top-link {
    display: inline-flex;
    align-items: center;
    padding: 8px 12px;
    font-size: 14px;
    color: $ink-soft;
    text-decoration: none;
    font-weight: 500;
    border-radius: $radius-sm;

    &:hover {
      color: $ink;
      background: rgba(20, 20, 20, 0.04);
    }

    &.active {
      color: $accent-deep;
    }
  }

  .nav-dd {
    position: relative;
  }

  .sub-panel {
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 0;
    min-width: min(100vw - 32px, 460px);
    padding: 14px 14px 16px;
    background: $paper;
    border: 1px solid $rule;
    border-radius: $radius;
    box-shadow: 0 10px 40px rgba(17, 21, 28, 0.08);
    opacity: 0;
    pointer-events: none;
    transform: translateY(6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  @media (max-width: $bp-sm) {
    .sub-panel {
      right: 0;
      left: 0;
      margin-left: auto;
      margin-right: auto;
    }
  }

  .nav-dd.is-open .sub-panel {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .sub-feature {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px 10px 14px;
    text-decoration: none;
    color: $ink;
    border-radius: $radius-sm;
    border: 1px solid $rule;
    background: $bg;
    margin-bottom: 10px;
    transition: border-color 0.15s ease, background 0.15s ease;

    &:hover {
      background: $paper-soft;
      border-color: color-mix(in srgb, $accent 35%, $rule 65%);
    }
  }

  .sub-feature-eyebrow {
    font-size: $fs-meta;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: $accent;
    font-weight: 600;
  }

  .sub-feature-title {
    font-family: $font-serif;
    font-size: 18px;
    font-weight: 600;
  }

  .sub-feature-hint {
    font-size: 13px;
    color: $ink-soft;
    line-height: 1.35;
  }

  .sub-tabs-wrap {
    border-top: 1px solid $rule-soft;
    padding-top: 12px;
  }

  .sub-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 8px;
    margin-bottom: 8px;
  }

  .sub-tab {
    position: relative;
    font-size: 13px;
    font-weight: 600;
    padding: 4px 8px;
    text-decoration: none;
    color: $ink-soft;
    border-radius: 6px;
    transition: color 0.16s ease, background 0.16s ease;

    &::after {
      content: "";
      position: absolute;
      left: 8px;
      right: 8px;
      bottom: 0;
      height: 2px;
      background: $accent;
      border-radius: 1px;
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.2s ease;
    }

    &:hover,
    &:focus {
      color: $ink;
      background: rgba(31, 58, 104, 0.06);
    }

    &:hover::after,
    &:focus::after,
    &.active::after {
      transform: scaleX(1);
    }

    &.active {
      color: $accent-deep;
    }
  }

  // — tab stage (image panels in People menu) ----------------------------------
  .tab-stage {
    position: relative;
    height: 110px;
    margin-top: 2px;
    overflow: hidden;
    border-radius: $radius-sm;
  }

  .tab-pane {
    position: absolute;
    inset: 0;
    display: none;
    gap: 12px;
    align-items: center;

    &.tab-pane-active { display: flex; }

    &.pane-entering {
      display: flex;
      animation: pane-in 180ms cubic-bezier(0.2, 0, 0, 1) both;
    }
    &.pane-exiting {
      display: flex;
      animation: pane-out 150ms cubic-bezier(0.4, 0, 1, 1) both;
    }
  }

  @keyframes pane-in {
    from { opacity: 0; transform: translateX(var(--x-in, 16px)); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes pane-out {
    from { opacity: 1; transform: translateX(0); }
    to   { opacity: 0; transform: translateX(var(--x-out, -16px)); }
  }

  .pane-img {
    width: 72px;
    flex-shrink: 0;
    border-radius: $radius-sm;
    align-self: stretch;
    position: relative;
    overflow: hidden;

    &::after {
      content: "";
      position: absolute;
      inset: 0;
      background-image: radial-gradient(circle, rgba(255,255,255,0.13) 1px, transparent 1px);
      background-size: 10px 10px;
    }

    &--groups  { background: linear-gradient(145deg, #1F3A68 0%, #2D5498 100%); }
    &--people  { background: linear-gradient(145deg, #B87328 0%, #D4943A 100%); }
    &--gallery { background: linear-gradient(145deg, #3D6B55 0%, #5A9B7A 100%); }
    &--crew    { background: linear-gradient(145deg, #2B5B72 0%, #3A82A4 100%); }
    &--alumni  { background: linear-gradient(145deg, #5C4033 0%, #8B6152 100%); }
  }

  .pane-info {
    display: flex;
    flex-direction: column;
    gap: 5px;
    flex: 1;
    min-width: 0;
  }

  .pane-desc {
    margin: 0;
    font-size: 12.5px;
    color: $ink-soft;
    line-height: 1.4;
  }

  .pane-link {
    font-size: 12.5px;
    font-weight: 600;
    color: $accent-deep;
    text-decoration: none;

    &:hover { text-decoration: underline; }
  }

  .actions {
    display: none;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .nav-cta-item :global(a.btn.header-cta),
  .actions :global(a.btn.header-cta) {
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 600;
    line-height: 1.2;
    text-decoration: none;
  }

  .nav-cta-item :global(a.btn.header-cta--primary.is-nav-active),
  .actions :global(a.btn.header-cta--primary.is-nav-active) {
    background: $accent-deep;
    border-color: $accent-deep;
  }

  .nav-cta-item :global(a.btn-ghost.header-cta.is-nav-active),
  .actions :global(a.btn-ghost.header-cta.is-nav-active) {
    color: $accent-deep;
    border-color: color-mix(in srgb, $accent-deep 45%, $ink 55%);
    background: $accent-soft;
  }

  @media (max-width: $bp-md) {
    .top-list > li.nav-cta-item {
      display: none;
    }
    .actions {
      display: flex;
    }
  }

  @media (max-width: $bp-sm) {
    .top-list {
      gap: 0;
    }

    .sub-trigger,
    .top-link {
      padding: 6px 8px;
      font-size: 13px;
    }
  }

  .nav-dd.is-open .chev {
    transform: rotate(180deg);
  }
</style>
