---
import { externalUrl } from "../data/members";

interface Props {
  name: string;
  website?: string;
  linkedin?: string;
  instagram?: string;
  github?: string;
}

const { name, website, linkedin, instagram, github } = Astro.props;

const items = [
  { key: "web", href: externalUrl(website), label: `${name} — website` },
  { key: "in", href: externalUrl(linkedin), label: `${name} on LinkedIn` },
  { key: "ig", href: externalUrl(instagram), label: `${name} on Instagram` },
  { key: "gh", href: externalUrl(github), label: `${name} on GitHub` },
].filter((x) => x.href);

const has = items.length > 0;
---

{has ? (
  <ul class="member-links" aria-label={`Links for ${name}`}>
    {items.map((x) => (
      <li>
        <a
          class="member-link"
          href={x.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${x.label} (opens in a new tab)`}
        >
          {x.key === "web" && (
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10" />
              <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
            </svg>
          )}
          {x.key === "in" && (
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M19 0H5C2.2 0 0 2.2 0 5v14c0 2.8 2.2 5 5 5h14c2.8 0 5-2.2 5-5V5c0-2.8-2.2-5-5-5zM8 19H5V8h3v11zM6.5 6.5a1.7 1.7 0 1 0 0-3.4 1.7 1.7 0 0 0 0 3.4zm12.5 13h-3v-5.6c0-1.3-.5-2.2-1.7-2.2-1 0-1.6.7-1.9 1.3V19h-3V8h2.6v1.2h.1c.3-.6 1.2-1.3 2.6-1.3 2.7 0 3.2 1.8 3.2 4V19z"
              />
            </svg>
          )}
          {x.key === "ig" && (
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
            </svg>
          )}
          {x.key === "gh" && (
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
          )}
        </a>
      </li>
    ))}
  </ul>
) : null}

<style lang="scss">
  .member-links {
    list-style: none;
    margin: 0 0 12px;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .member-link {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 999px;
    color: $ink-soft;
    background: $bg;
    border: 1px solid $rule;
    text-decoration: none;
    transition:
      color 0.12s ease,
      background 0.12s ease,
      border-color 0.12s ease,
      transform 0.12s ease;

    &:hover {
      color: $accent-deep;
      background: $paper-soft;
      border-color: $accent-soft;
      transform: translateY(-1px);
    }
  }
</style>
