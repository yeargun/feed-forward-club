---
import { applyPath, contactPath, siteTagline } from "../data/config";
import { memberStatus } from "../data/batches";
import Logo from "./Logo.astro";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wide foot-inner">
    <div class="foot-grid">
      <div class="col brand-col">
        <a href="/" class="foot-logo-link" aria-label="FeedForwardClub home">
          <Logo variant="wordmark" class="footer-logo" />
        </a>
        <p class="tag-line">{siteTagline}</p>
      </div>
      <nav class="col nav-col" aria-label="Site pages">
        <h4>Pages</h4>
        <ul>
          <li><a href="/manifesto">Manifesto</a></li>
          <li><a href="/groups">Groups</a></li>
          <li><a href="/people">People</a></li>
          <li><a href="/gallery">Gallery</a></li>
          <li><a href="/crew">Crew</a></li>
          <li><a href="/alumnis">Alumni</a></li>
          <li><a href="/events">Events</a></li>
          <li><a href="/news">News</a></li>
        </ul>
      </nav>
      <div class="col cta-col">
        <h4>Get in</h4>
        {memberStatus.accepting && (
          <p class="session-line">
            Sessions running — <a href={applyPath} class="join-link">join the circle</a>
          </p>
        )}
        <div class="foot-cta">
          <a href={applyPath} class="btn">Apply</a>
          <a href={contactPath} class="btn btn-ghost">Contact</a>
        </div>
      </div>
    </div>
  </div>
  <div class="foot-base">
    <div class="wide foot-base-inner">
      <p class="copyright">© {year} FeedForwardClub</p>
      <span class="base-sep" role="presentation" aria-hidden="true" />
      <p class="motto"><em>Small rooms. Audacious goals.</em></p>
    </div>
  </div>
</footer>

<style lang="scss">
  .site-footer {
    position: relative;
    margin-top: clamp(64px, 10vw, 100px);
    background:
      radial-gradient(ellipse 90% 180% at 50% 0%, rgba(31, 58, 104, 0.07) 0%, transparent 55%),
      $bg-deep;
    font-size: 14px;
    color: $ink-soft;

    &::before {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      top: 0;
      height: 1px;
      background: linear-gradient(
        90deg,
        transparent 0%,
        color-mix(in srgb, $accent 35%, $rule) 20%,
        color-mix(in srgb, $accent 35%, $rule) 80%,
        transparent 100%
      );
    }
  }

  .foot-inner {
    padding: clamp(48px, 5vw, 72px) $pad 0;
  }

  .foot-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1.4fr) minmax(0, 260px);
    gap: clamp(28px, 4vw, 48px);
    align-items: start;
    padding-bottom: clamp(40px, 5vw, 56px);
    border-bottom: 1px solid $rule;
  }

  .col h4 {
    font-family: $font-sans;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: $accent-deep;
    font-weight: 600;
    margin: 0 0 16px;
  }

  .nav-col {
    min-width: 0;

    ul {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: 1fr 1fr;
      column-gap: clamp(20px, 3vw, 40px);
      row-gap: 4px;
    }

    a {
      display: inline-block;
      text-decoration: none;
      color: $ink;
      font-size: 14px;
      line-height: 1.5;
      padding: 3px 0;
      border-radius: 2px;
      transition: color 0.12s ease, background 0.12s ease;

      &:hover {
        color: $accent-deep;
      }
    }
  }

  .foot-logo-link {
    display: inline-block;
    line-height: 0;
    text-decoration: none;
    border-radius: 4px;
    outline-offset: 4px;
    color: inherit;

    &:hover :global(svg) {
      opacity: 0.92;
    }
  }

  .footer-logo {
    width: 184px;
    max-width: 100%;
    height: auto;
    display: block;
  }

  .tag-line {
    font-family: $font-serif;
    font-size: 15px;
    color: $ink-soft;
    margin: 14px 0 0;
    max-width: 20rem;
    line-height: 1.5;
  }

  .cta-col {
    .session-line {
      margin: 0 0 16px;
      font-size: 14px;
      line-height: 1.5;
      color: $ink-soft;
    }

    .join-link {
      font-weight: 600;
      color: $ink;
      text-decoration: none;
      border-bottom: 1px solid color-mix(in srgb, $accent 40%, $rule);
      transition: color 0.12s ease, border-color 0.12s ease;

      &:hover {
        color: $accent-deep;
        border-color: $accent;
      }
    }
  }

  .foot-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .cta-col :global(.btn) {
    padding: 10px 18px;
    font-size: 13px;
  }

  .foot-base {
    background: color-mix(in srgb, $ink 1.2%, $bg-deep);
  }

  .foot-base-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 12px 20px;
    padding: 20px $pad 28px;
    text-align: center;
    color: $muted;
    font-size: 13px;
  }

  .copyright,
  .motto {
    margin: 0;
  }

  .copyright {
    color: $muted;
  }

  .motto {
    font-family: $font-serif;
    font-size: 14px;
    color: $ink-soft;
    letter-spacing: 0.01em;

    em {
      font-style: italic;
    }
  }

  .base-sep {
    display: block;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: color-mix(in srgb, $accent 45%, $muted);
    flex-shrink: 0;
  }

  @media (min-width: 640px) {
    .foot-base-inner {
      flex-wrap: nowrap;
      justify-content: space-between;
      text-align: left;
    }
  }

  @media (max-width: 639px) {
    .foot-base-inner {
      flex-direction: column;
      gap: 8px;
    }

    .base-sep {
      display: none;
    }
  }

  @media (max-width: $bp-lg) {
    .foot-grid {
      grid-template-columns: 1fr 1fr;
    }

    .brand-col {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: $bp-md) {
    .nav-col ul {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: $bp-sm) {
    .foot-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
