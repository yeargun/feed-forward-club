---
import type { Chapter } from "../data/groups";
import { chapterMarkerColor, statusLabel } from "../data/groups";
import type { CountryBucket } from "../data/members";

interface Props {
  /** Geographic chapters to render. Arcs are drawn from active → others. */
  chapters: Chapter[];
  size?: number;
  /** Slug of chapter to face the camera at load. Defaults to first active. */
  home?: string;
  /** Auto-rotation speed (radians/frame). 0 to pause. Default 0.0025. */
  speed?: number;
  /** Show status legend + chapter pills below the globe. */
  meta?: boolean;
  /** Total members across all chapters (for the number badge). */
  memberCount?: number;
  /** Per-country counts with flags (rendered as pills). */
  countries?: CountryBucket[];
}

const {
  chapters,
  size = 400,
  home,
  speed = 0.0025,
  meta = true,
  memberCount,
  countries,
} = Astro.props;

const homeChapter =
  (home && chapters.find((c) => c.slug === home)) ||
  chapters.find((c) => c.status === "active") ||
  chapters[0];

const initialPhi = homeChapter ? -(homeChapter.lon * Math.PI) / 180 : 0;

const markers = chapters.map((c) => ({
  id: c.slug,
  location: [c.lat, c.lon] as [number, number],
  size:
    c.status === "active" ? 0.1
    : c.status === "forming" ? 0.06
    : 0.035,
  color: chapterMarkerColor[c.status],
}));

const activeChapters = chapters.filter((c) => c.status === "active");
const others = chapters.filter((c) => c.status !== "active");
const arcs = activeChapters.flatMap((a) =>
  others.map((o) => ({
    from: [a.lat, a.lon] as [number, number],
    to: [o.lat, o.lon] as [number, number],
  })),
);
---

<div class="globe" style={`--g-size: ${size}px;`}>
  <div class="canvas-wrap">
    <canvas
      id="ffc-globe"
      class="canvas"
      data-initial-phi={initialPhi}
      data-speed={speed}
      data-markers={JSON.stringify(markers)}
      data-arcs={JSON.stringify(arcs)}
      aria-label="Interactive globe showing FeedForwardClub chapters. Click and drag to rotate."
    ></canvas>

    {memberCount != null && (
      <div class="member-badge">
        <div class="n">{memberCount}</div>
        <div class="l">{memberCount === 1 ? "member" : "members"}</div>
      </div>
    )}

    <div class="drag-hint" aria-hidden="true">drag to rotate</div>
  </div>

  {meta && (
    <div class="meta">
      {countries && countries.length > 0 && (
        <div class="countries">
          {countries.map((c) => (
            <span class="country-pill" title={`${c.count} ${c.count === 1 ? "member" : "members"}`}>
              <span class="flag">{c.flag}</span>
              {c.name}
              <span class="cnt">{c.count}</span>
            </span>
          ))}
        </div>
      )}

      <div class="legend">
        <span class="dot s-active" aria-hidden="true"></span>
        <span class="l">{statusLabel.active}</span>
        <span class="sep">·</span>
        <span class="dot s-forming" aria-hidden="true"></span>
        <span class="l">{statusLabel.forming}</span>
        <span class="sep">·</span>
        <span class="dot s-planned" aria-hidden="true"></span>
        <span class="l">{statusLabel.planned}</span>
      </div>
    </div>
  )}
</div>

<script>
  import createGlobe from "cobe";

  const canvas = document.getElementById("ffc-globe") as HTMLCanvasElement | null;
  if (canvas) {
    const wrap = canvas.closest(".canvas-wrap") as HTMLElement | null;
    const markers = JSON.parse(canvas.dataset.markers ?? "[]");
    const arcs = JSON.parse(canvas.dataset.arcs ?? "[]");
    const initialPhi = Number(canvas.dataset.initialPhi ?? 0);
    const speed = Number(canvas.dataset.speed ?? 0.0025);
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    let phi = initialPhi;
    let width = 0;
    const measure = () => { width = canvas.offsetWidth; };
    measure();
    window.addEventListener("resize", measure);

    // Drag state
    let dragging = false;
    let lastX = 0;
    let dragged = false; // any movement at all? used to hide the hint on first interaction

    canvas.addEventListener("pointerdown", (e) => {
      dragging = true;
      lastX = e.clientX;
      canvas.setPointerCapture?.(e.pointerId);
      canvas.style.cursor = "grabbing";
      wrap?.classList.add("dragging");
    });
    const release = (e: PointerEvent) => {
      if (!dragging) return;
      dragging = false;
      canvas.releasePointerCapture?.(e.pointerId);
      canvas.style.cursor = "grab";
      wrap?.classList.remove("dragging");
    };
    canvas.addEventListener("pointerup", release);
    canvas.addEventListener("pointercancel", release);
    canvas.addEventListener("pointerleave", release);

    canvas.addEventListener("pointermove", (e) => {
      if (!dragging) return;
      const dx = e.clientX - lastX;
      lastX = e.clientX;
      phi += dx / 200;
      if (!dragged && Math.abs(dx) > 2) {
        dragged = true;
        wrap?.classList.add("dragged");
      }
    });

    const globe = createGlobe(canvas, {
      devicePixelRatio: 2,
      width: width * 2,
      height: width * 2,
      phi,
      theta: 0.28,
      dark: 0.08,
      diffuse: 1.2,
      mapSamples: 16000,
      mapBrightness: 3.4,
      baseColor: [0.34, 0.34, 0.30],
      markerColor: [0.122, 0.227, 0.408],
      glowColor: [0.96, 0.94, 0.90],
      markers,
      arcs,
      arcColor: [0.55, 0.65, 0.85],
      arcWidth: 0.4,
      arcHeight: 0.3,
      markerElevation: 0.04,
    });

    const tick = () => {
      if (!dragging && !prefersReduced) phi += speed;
      globe.update({ phi, width: width * 2, height: width * 2 });
      requestAnimationFrame(tick);
    };
    tick();
  }
</script>

<style lang="scss">
  .globe {
    position: relative;
    max-width: var(--g-size);
    margin-left: auto;
  }

  .canvas-wrap {
    aspect-ratio: 1 / 1;
    width: 100%;
    position: relative;
    display: grid;
    place-items: center;

    &::before {
      content: "";
      position: absolute;
      inset: -6%;
      background: radial-gradient(
        closest-side,
        rgba(31, 58, 104, 0.14),
        transparent 70%
      );
      z-index: 0;
      pointer-events: none;
    }
  }

  .canvas {
    width: 100%;
    height: 100%;
    position: relative;
    z-index: 1;
    cursor: grab;
    touch-action: pan-y;
    contain: layout paint;
    user-select: none;
    -webkit-user-select: none;
  }

  .member-badge {
    position: absolute;
    left: 0;
    bottom: 8%;
    z-index: 2;
    pointer-events: none;
    background: color-mix(in srgb, $bg 88%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid $rule;
    border-radius: $radius;
    padding: 10px 14px;
    display: grid;
    gap: 2px;
    box-shadow: 0 2px 12px $shadow;

    .n {
      font-family: $font-serif;
      font-size: 32px;
      line-height: 1;
      color: $ink;
    }
    .l {
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: $muted;
      font-weight: 600;
    }
  }

  .drag-hint {
    position: absolute;
    right: 10px;
    top: 10px;
    z-index: 2;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: $muted;
    background: color-mix(in srgb, $bg 80%, transparent);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    padding: 4px 8px;
    border-radius: 999px;
    border: 1px solid $rule;
    pointer-events: none;
    transition: opacity 400ms ease;
  }
  .canvas-wrap.dragged .drag-hint { opacity: 0; }

  .meta {
    margin-top: 18px;
    display: grid;
    gap: 12px;
  }

  .countries {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .country-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px 4px 6px;
    background: $paper;
    border: 1px solid $rule;
    border-radius: 999px;
    font-size: 13px;
    color: $ink-soft;

    .flag {
      font-size: 15px;
      line-height: 1;
    }
    .cnt {
      font-weight: 600;
      color: $ink;
      font-size: 12px;
      padding: 1px 6px;
      background: $accent-soft;
      color: $accent-deep;
      border-radius: 999px;
    }
  }

  .legend {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: $muted;
    font-weight: 600;
    flex-wrap: wrap;

    .sep { color: $rule; }
    .l { color: $ink-soft; font-weight: 500; letter-spacing: 0.05em; text-transform: none; }
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;

    &.s-active {
      background: $accent;
      box-shadow: 0 0 0 3px $accent-soft;
    }
    &.s-forming {
      background: color-mix(in srgb, $accent 55%, $muted 45%);
    }
    &.s-planned {
      background: $muted;
      opacity: 0.7;
    }
  }

  @media (max-width: $bp-md) {
    .globe { margin: 0 auto; }
    .member-badge {
      bottom: 4%;
      padding: 8px 12px;
      .n { font-size: 24px; }
    }
  }
</style>
