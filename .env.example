# FeedForwardClub — environment variables.
# Copy this file to `.env` and fill in real endpoints.
#
# Any variable prefixed with PUBLIC_ is exposed to the client-side bundle at
# build time (per Astro's env conventions). Do NOT put secrets under PUBLIC_.

# Canonical site URL (no trailing slash). Used for SEO, sitemap, and robots.
PUBLIC_SITE_URL=https://feedforwardclub.com

# Public mailboxes shown on the site and in mailto links.
PUBLIC_CONTACT_EMAIL=hi@feedforwardclub.com
PUBLIC_APPLY_EMAIL=contact@feedforwardclub.com

# Where the /apply form POSTs its JSON payload.
# Your backend should accept a POST with Content-Type: application/json.
PUBLIC_APPLY_ENDPOINT=https://api.feedforwardclub.com/apply

# Where the /contact form POSTs its JSON payload.
PUBLIC_CONTACT_ENDPOINT=https://api.feedforwardclub.com/contact

# Optional: public Google Calendar (or other) embed URL for the home page and /events.
# In Google Calendar: Settings → Integrate calendar → copy the "Embed code" src URL.
# PUBLIC_CALENDAR_EMBED_URL=https://calendar.google.com/calendar/embed?src=...&ctz=Etc%2FGMT

# Optional: iCal / subscribe link (Google: same settings page → "Secret address in iCal format").
# PUBLIC_CALENDAR_ICS_URL=https://calendar.google.com/calendar/ical/.../public/basic.ics

# Upcoming event lists refetch /calendar.json in the browser by default (set PUBLIC_LIVE_CALENDAR=false to turn off).
# PUBLIC_LIVE_CALENDAR=false
# PUBLIC_CALENDAR_JSON_URL=/calendar.json
#
# Hot-updates without a full site deploy: add KV in wrangler.toml, redeploy, then:
#   npm run calendar:push
# (writes `src/data/calendar.json` to the `data` key; Worker serves it at /calendar.json before static files.)
