# FeedForwardClub submission server — environment variables.
# Copy to `.env` and edit as needed.

# Port to listen on.
PORT=3000

# Where JSONL submission files land. Created if missing.
DATA_DIR=./data

# CORS allowlist. Comma-separated origins. Use "*" to allow any.
# In production, lock this to your live + preview domains.
ALLOWED_ORIGINS=http://localhost:4321,https://feedforwardclub.com
